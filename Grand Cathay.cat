    <profile name="Cathayan Cataphracts" typeId="c1ac-c1c8-f9d5-9673" typeName="Special Rule" hidden="false" id="4cef-4823-4dd5-a26a">
      <characteristics>
        <characteristic name="Description" typeId="9f84-4221-785a-db50">When a unit in which the majority of the models have this special rule makes a follow up move, the unit counts as having charged during the next turn.</characteristic>
      </characteristics>
    </profile>
