    <profile name="Defensive Stance" typeId="c1ac-c1c8-f9d5-9673" typeName="Special Rule" hidden="false" id="bd90-2e9b-ed27-5498">
      <characteristics>
        <characteristic name="Description" typeId="9f84-4221-785a-db50">Unless it charged during the preceding Movement phase, or counts as having charged this turn, a unit with this special rule may re-roll any Armour Save rolls of a natural 1 made during the Combat phase.</characteristic>
      </characteristics>
    </profile>
    <profile name="Jade Lancer" typeId="b070-143a-73f-2772" typeName="Model" hidden="false" id="be61-1dc1-4cd1-2805">
