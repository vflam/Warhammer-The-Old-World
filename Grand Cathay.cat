    <profile name="Harmony of Stone &amp; Steel" typeId="c1ac-c1c8-f9d5-9673" typeName="Special Rule" hidden="false" id="fcda-2bba-91ce-ea11">
      <characteristics>
        <characteristic name="Description" typeId="9f84-4221-785a-db50">A unit joined by a character with this special rule may re-roll any failed Leadership test when attempting to reform after running down a foe, when attempting to redirect a charge, or when making a Restraint test.</characteristic>
      </characteristics>
    </profile>
