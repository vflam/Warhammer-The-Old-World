    <profile name="Warriors of the Field" typeId="c1ac-c1c8-f9d5-9673" typeName="Special Rule" hidden="false" id="1c8c-f022-c886-80fe">
      <characteristics>
        <characteristic name="Description" typeId="9f84-4221-785a-db50">Units of Peasant Levy do not become Disrupted by difficult or dangerous terrain.</characteristic>
      </characteristics>
    </profile>
    <profile name="Warriors of the Land" typeId="c1ac-c1c8-f9d5-9673" typeName="Special Rule" hidden="false" id="eacf-da93-a344-f8da">
      <characteristics>
        <characteristic name="Description" typeId="9f84-4221-785a-db50">When a unit of Peasant Levy Falls Back in Good Order, it may choose which dice to discard when making its Flee roll, rather than automatically discarding the lowest result.</characteristic>
      </characteristics>
    </profile>
    <profile name="Warriors of the Wind" typeId="c1ac-c1c8-f9d5-9673" typeName="Special Rule" hidden="false" id="8578-63d2-29ea-5e34">
      <characteristics>
        <characteristic name="Description" typeId="9f84-4221-785a-db50">0-1 unit of Peasant Levy per 1,000 points may have the Reserve Move and Scouts special rules for + 2 points per model.</characteristic>
      </characteristics>
    </profile>
