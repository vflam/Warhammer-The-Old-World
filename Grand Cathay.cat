    <profile name="Long spear" typeId="a378-c633-912d-11ce" typeName="Weapon" hidden="false" id="2f5b-4f01-c2bb-808e">
      <characteristics>
        <characteristic name="R" typeId="2360-c777-5e07-ed58">Combat</characteristic>
        <characteristic name="S" typeId="ac19-f99c-72e9-a1a7">S</characteristic>
        <characteristic name="AP" typeId="9429-ffe7-2ce5-e9a5">-</characteristic>
        <characteristic name="Special Rules" typeId="5f83-3633-336b-93b4">Fight in Extra Rank, Strike First</characteristic>
        <characteristic name="Notes" typeId="772a-a7ff-f6b3-df71">Model&apos;s whose troop type is &apos;infantry&apos; only. A model wielding a long spear cannot make a supporting attack during a turn in which it charged. A long spear&apos;s Strike First special rule applies only against charging enemy units.</characteristic>
      </characteristics>
    </profile>
