    </profile>
    <profile name="Tower Shields" typeId="c14f-740-8107-d34b" typeName="Armour" hidden="false" id="2402-26bb-2fef-12d9">
      <characteristics>
        <characteristic name="Description" typeId="adcd-c649-e6fc-a9f6">A tower shield is a shield that improves its wielder&apos;s armour value by 3 (rather than the usual 1) against attacks made by enemy models that lie within the wielder&apos;s front arc. However, a tower shield offers no protection to its wielder against attacks made by enemy models that lie within the wielder&apos;s flank or rear arcs.</characteristic>
      </characteristics>
    </profile>
    <profile name="Iron Hail Gunner" typeId="b070-143a-73f-2772" typeName="Model" hidden="false" id="76a6-4703-d3a6-ed7e">
      <characteristics>
        <characteristic name="M" typeId="cd3b-a5a4-e185-5a9d">4</characteristic>
