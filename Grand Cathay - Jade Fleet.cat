  <rules>
    <rule name="Cathayan Black Powder" id="e7e4-fc0b-cb90-8f2e" hidden="false">
      <description>The first time any unit in a Jade Fleet army that is armed with a handgun, a pistol, a brace of pistols, a repeater handgun, or a repeater pistol shoots the range of that weapon is increased by 3&quot;.</description>
    </rule>
    <rule name="Mercenary Handgun Drill" id="6017-131c-2a11-5bed" hidden="false">
      <description>Once per game, each unit or detachment of State Missile Troops in a Jade Fleet army can fire with one additional rank.</description>
    </rule>
    <rule name="Unity &amp; Harmony" id="7264-b54d-0754-4f11" hidden="false">
      <description>Any unit of Jade Warriors or Jade Lancers within 3&quot; of a friendly Mercenary unit may re-roll To Hit rolls of 1 during the Combat phase.</description>
    </rule>
    <rule name="War Balloons" id="2445-fdcd-ba4d-ffea" hidden="false">
      <description>0-1 Sky Lantern per 1,000 points may have the Ambushers special rule for +15 points. In addition, once per game a Sky Lantern that is held in reserve may re-roll the dice to determine if it arrives as reinforcements or is delayed.</description>
    </rule>
  </rules>
</catalogue>
